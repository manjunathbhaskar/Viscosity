# Where this service reaches Ollama. Default assumes it's running locally.
OLLAMA_BASE_URL=http://localhost:11434

# Which Ollama tags to use for each stage. Defaults below are what the
# pipeline was built and tuned against — see README.md for VRAM notes on
# swapping to smaller tags.
VISCOSITY_SWARM_MODEL=llama3.2:3b
VISCOSITY_RISK_MODEL=phi4:14b
VISCOSITY_SYNTHESIS_MODEL=mistral-small:24b

# Reviewer swarm size: 25 (turbo, default) | 50 (standard) | 200 (deep).
# Overridden per-request by web/'s swarm-bridge.ts if it sends `citizens`.
VISCOSITY_SWARM_SIZE=25

# Port this Flask service listens on.
PORT=5100
