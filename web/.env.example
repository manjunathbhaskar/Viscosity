# Deterministic demo mode — zero external calls, zero diligence-service dependency.
# Set this for the judged demo.
VCBRAIN_MOCK=1

# External diligence service base URL — only used when VCBRAIN_MOCK is unset.
DILIGENCE_BASE_URL=http://localhost:5000

# Optional — enables direct Claude API calls (tier 2 of agent/crew/brain.ts).
# Without this, the Claude Agent SDK managed-agent fallback is tried instead;
# without either, think() returns null and the deterministic scoring path
# (which never needs an LLM call) still works fully.
ANTHROPIC_API_KEY=

# Optional web pulse — Tavily (a.k.a. Travily) live search tool. Safe to leave unset; mocked in VCBRAIN_MOCK.
TAVILY_API_KEY=HackNationJuly

# Optional audio brief generator — ElevenLabs text-to-speech. Leave unset to skip audio outputs.
# Also powers voice Q&A/briefings (lib/voice-briefing.ts) — without a key those
# endpoints degrade gracefully to text-only responses.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional adversarial swarm sidecar base URL (BlackSwanX-derived NEXUS service). Example: http://localhost:5050
SWARM_BASE_URL=

# Optional enrichment tool keys — all guarded, absence just skips that source.
GITHUB_TOKEN=
PRODUCTHUNT_TOKEN=

# X (Twitter) founder-signal tool — official X API v2, Bearer token.
# Without it, agent/tools/x.ts returns null (source skipped), same as every
# other optional tool in this directory.
X_BEARER_TOKEN=

# Patents tool (agent/tools/patents.ts) — PatentsView API. Without it,
# patent search is skipped. NOT live-verified (no key available during
# development) — built to PatentsView's documented v1 contract; re-verify
# the response shape in agent/tools/patents.ts before trusting it live.
PATENTSVIEW_API_KEY=

# ElevenLabs voice agent — enables spoken deal briefings and voice Q&A.
# Without it, voice endpoints return text-only responses (graceful degradation).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
